# Copy to a private environment file; do not commit the real file.
AI_BASE_URL=http://127.0.0.1:8317/v1
AI_API_KEY=
AI_MODEL=grok-4.5
AI_MODEL_NAME=Grok 4.5
AI_SETTINGS_PATH=/etc/account-ai-ai.json
ACCOUNT_SECRET=replace-with-a-long-random-secret
ACCOUNT_MAX_ROWS=5000
SITE_NAME=现金流AI
ADMIN_EMAILS=admin@example.com
SESSION_COOKIE_SECURE=1
SESSION_COOKIE_SAMESITE=Lax

# Registration email verification via toolkit SMTP Console
MAIL_API_URL=http://127.0.0.1:18430/api/send
MAIL_FROM_NAME=现金流 AI
EMAIL_VERIFY_TTL=600
EMAIL_VERIFY_RESEND_COOLDOWN=60
EMAIL_VERIFY_MAX_ATTEMPTS=5
EMAIL_VERIFY_MAX_PER_HOUR=5
